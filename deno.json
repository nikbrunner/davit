{
  "version": "1.0.0",
  "tasks": {
    "dev": "deno run --allow-net --allow-read --allow-env src/index.ts",
    "test": "deno test --allow-read --allow-env tests/cli/ tests/core/",
    "test:integration": "deno test --allow-net --allow-read --allow-env tests/integration/",
    "lint": "deno lint",
    "fmt": "deno fmt",
    "fmt:check": "deno fmt --check",
    "install": "deno install --global -f --allow-net --allow-read --allow-env --name davit --config deno.json src/index.ts",
    "compile": "deno compile --allow-net --allow-read --allow-env --output dist/davit src/index.ts",
    "check": "deno check src/**/*.ts",
    "checks": "deno task fmt:check && deno task lint && deno task check && deno task test",
    "setup-git-hooks": "bash scripts/setup-git-hooks.sh"
  },
  "imports": {
    "tsdav": "npm:tsdav@2.1.8",
    "@cliffy/command": "jsr:@cliffy/command@^1.0.0",
    "@std/toml": "jsr:@std/toml@^1",
    "@std/assert": "jsr:@std/assert@^1",
    "chrono-node": "npm:chrono-node@2.7.7"
  },
  "compilerOptions": {
    "strict": true,
    "noUncheckedIndexedAccess": true
  }
}
