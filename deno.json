{
  "name": "@nikbrunner/davit",
  "version": "0.1.0",
  "tasks": {
    "dev": "deno run --allow-net --allow-read --allow-env src/index.ts",
    "test": "deno test --allow-read --allow-env",
    "lint": "deno lint",
    "fmt": "deno fmt",
    "fmt:check": "deno fmt --check",
    "compile": "deno compile --allow-net --allow-read --allow-env --output dist/davit src/index.ts"
  },
  "imports": {
    "tsdav": "npm:tsdav@2.1.8",
    "@modelcontextprotocol/sdk/": "npm:@modelcontextprotocol/sdk@1.12.1/",
    "zod": "npm:zod@3.25.67",
    "@cliffy/command": "jsr:@cliffy/command@^1.0.0",
    "@std/toml": "jsr:@std/toml@^1",
    "@std/assert": "jsr:@std/assert@^1"
  },
  "compilerOptions": {
    "strict": true,
    "noUncheckedIndexedAccess": true
  }
}
